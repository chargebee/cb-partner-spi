{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "$ref": "#/definitions/ProviderCapabilitySchema",
  "definitions": {
    "ProviderCapabilitySchema": {
      "type": "object",
      "description": "The main schema that defines the structure of both E-invoicing Provider's production and sandbox capabilities.",
      "additionalProperties": false,
      "properties": {
        "prod": {
          "$ref": "#/definitions/CapabilityBody"
        },
        "sandbox": {
          "$ref": "#/definitions/CapabilityBody"
        }
      },
      "required": [
        "prod",
        "sandbox"
      ],
      "title": "ProviderCapabilitySchema"
    },
    "CapabilityBody": {
      "type": "object",
      "description": "Specifies the capabilities and configurations of the E-invoicing Provider for a given environment (e.g., production or sandbox).",
      "additionalProperties": false,
      "properties": {
        "identity_configuration": {
          "$ref": "#/definitions/IdentityConfiguration",
          "description": "Specifies Identity Configuration details of the E-invoicing provider such as Logo url, description, compliance related details."
        },
        "api_configuration": {
          "$ref": "#/definitions/APIConfiguration",
          "description": "Specifies API configuration details of the E-invoicing provider including the base URL and any necessary credentials."
        },
        "capabilities": {
          "$ref": "#/definitions/Capabilities",
          "description": "Specifies the capabilities supported by the E-invoicing provider with additional details such as supported countries and currencies."
        },
        "supported_number_of_line_items": {
          "type": "integer",
          "description": "Specifies the supported number of line items in an invoice or a credit note.",
          "examples": [
            1200
          ]
        }
      },
      "required": [
        "api_configuration",
        "capabilities",
        "identity_configuration",
        "supported_number_of_line_items"
      ],
      "title": "Prod"
    },
    "APIConfiguration": {
      "type": "object",
      "description": "Specifies API configuration details of the E-invoicing provider including the base URL and any necessary credentials.",
      "additionalProperties": false,
      "properties": {
        "api_base_url": {
          "type": "string",
          "description": "Specifies the E-invoicing provider's Base URL.",
          "format": "uri",
          "qt-uri-protocols": [
            "https"
          ],
          "examples": [
            "https://api.einvoice-provider.com/integrations/chargebee/api/v1"
          ]
        },
        "credential_configuration": {
          "type": "array",
          "description": "Specifies the list of parameters that the E-invoicing provider needs for authentication & authorization.",
          "items": {
            "$ref": "#/definitions/CredentialConfiguration"
          }
        },
        "chargebee_oauth": {
          "type": "object",
          "description": "OAuth authentication configuration for integrating Chargebee with the E-invoicing provider. Specifies the OAuth type and the redirect URI used for the authorization callback.",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "OAUTH2"
              ],
              "description": "The OAuth type."
            },
            "redirect_uri": {
              "type": "string",
              "format": "uri",
              "description": "The redirect URI to which the E-invoicing provider will send the authorization code after successful authentication."
            }
          },
          "required": ["type", "redirect_uri"]
        },
        "webhook_configuration": {
          "type": "object",
          "description": "Defines how the E-invoicing provider sends webhook notifications to Chargebee, including endpoint URL and authentication details.",
          "properties": {
            "endpoint_url": {
              "type": "string",
              "format": "uri",
              "description": "The endpoint URL where Chargebee will receive webhook notifications from the E-invoicing provider."
            },
            "webhook_authentication": {
              "type": "object",
              "description": "Specifies the authentication mechanism for validating webhook requests. Supports HMAC or Basic Auth with details about where the authentication fields appear and the algorithms used.",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "HMAC",
                    "BASIC_AUTH"
                  ],
                  "description": "The type of webhook authentication."
                },
                "location": {
                  "type": "string",
                  "enum": [
                    "body",
                    "header"
                  ],
                  "description": "Where the webhook authentication field appears (request body or header)."
                },
                "field_path": {
                  "type": "string",
                  "description": "The JSON path or key path to the HMAC or authentication value in the webhook body."
                },
                "algorithm_path": {
                  "type": "string",
                  "description": "The JSON path or key path to the algorithm specification in the webhook body, if applicable."
                },
                "header_name": {
                  "type": "string",
                  "description": "The header name where the authentication value is sent if using header-based authentication."
                },
                "algorithm": {
                  "type": "string",
                  "description": "The HMAC or signature algorithm used (e.g., SHA-256)."
                },
                "fields": {
                  "type": "array",
                  "description": "Array of fields required to configure the webhook authentication, e.g., secret keys.",
                  "items": {
                    "$ref": "#/definitions/CredentialConfiguration"
                  }
                }
              },
              "required": ["type", "location", "fields"]
            }
          },
          "required": ["endpoint_url", "webhook_authentication"]
        }
      },
      "required": [
        "api_base_url",
        "credential_configuration"
      ],
      "examples": [
        {
          "api_base_url": "https://api.avalara-einv.com/integrations/chargebee/api/v1",
          "credential_configuration": [
            {
              "id": "api_key",
              "is_required": true,
              "is_sensitive": true,
              "name": "Avalara API Key",
              "type": "text"
            }
          ],
          "chargebee_oauth": {
            "type": "OAUTH2",
            "redirect_uri": "https://app.chargebee.com/oauth/callback"
          },
          "webhook_configuration": {
            "endpoint_url": "https://app.chargebee.com/einvoicing/webhooks/<einvoicing_provider_id>",
            "webhook_authentication": {
              "type": "HMAC",
              "location": "body",
              "field_path": "items[0].signature.value",
              "algorithm_path": "items[0].signature.algorithm",
              "fields": [
                {
                  "id": "webhook_secret_key",
                  "name": "Avalara Webhook Secret",
                  "type": "password",
                  "is_required": true,
                  "is_sensitive": true
                }
              ]
            }
          }
        }
      ],
      "title": "APIConfiguration"
    },
    "CredentialConfiguration": {
      "type": "object",
      "description": "Specifies the list of parameters that the E-invoicing provider needs for authentication & authorization.",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Specifies the parameter name that the E-invoicing provider expects.",
          "examples": [
            "api_key"
          ]
        },
        "name": {
          "type": "string",
          "description": "Specifies the name of parameter to be displayed in the E-invoicing provider app on Chargebee platform.",
          "examples": [
            "E-invoicing Provider API Key"
          ]
        },
        "type": {
          "type": "string",
          "description": "Specifies the type of the parameter.",
          "enum": [
            "text",
            "password"
          ]
        },
        "is_sensitive": {
          "type": "boolean",
          "description": "Specifies the the case sensitivity of the parameter."
        },
        "is_required": {
          "type": "boolean",
          "description": "Specifies if the E-invoicing provider expects this parameter mandatorily."
        },
        "multi_entity_support": {
          "type": "boolean",
          "description": "Specifies if the parameter supports multiple values for different accounts of same merchant."
        }
      },
      "required": [
        "id",
        "is_required",
        "is_sensitive",
        "name",
        "type"
      ],
      "examples": [
        {
          "id": "api_key",
          "is_required": true,
          "is_sensitive": true,
          "name": "Avalara API Key",
          "type": "text"
        }
      ],
      "title": "CredentialConfiguration"
    },
    "Capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "supported_countries": {
          "type": "array",
            "items": {
                "type": "string"
                },
            "examples": [
                "DE", "AT", "FR", "IT", "ES", "NL", "PL", "PT", "SE", "FI", "NO", "DK", "BE"
            ],
          "description": "Specifies the countries(ISO 3166 alpha-2 country code format) supported by the E-invoicing provider."
        },
        "supported_currencies": {
          "type": "array",
          "description": "Specifies the supported currencies(ISO 4217 format) by the E-invoicing provider for the E-invoicing capability",
          "items": {
            "type": "string"
          },
          "examples": [
            "USD", "EUR", "GBP", "AUD", "CAD", "JPY", "INR", "CNY", "BRL", "MXN"
          ]
        },
        "retrieve_activation_supported": {
          "type": "boolean",
          "description": "Specifies if retrieving merchant activation info from the E-invoicing provider portal via Chargebee is supported."
        },
        "retrieve_business_entities_supported": {
          "type": "boolean",
          "description": "Specifies if retrieving the list of business entities configured in the E-invoicing provider portal via Chargebee is supported."
        },
        "retrieve_input_fields_supported": {
          "type": "boolean",
          "description": "Specifies if retrieving data input fields from the E-invoicing provider via Chargebee is supported."
        },
        "retrieve_einvoice_status_supported": {
          "type": "boolean",
          "description": "Specifies if fetching e-invoice status for a given invoice is supported."
        },
        "customer_identifiers": {
          "$ref": "#/definitions/CustomerIdentifiers",
          "description": "Specifies the customer identifiers required for E-invoicing in different countries."
        },
        "document_download": {
          "$ref": "#/definitions/DocumentDownload",
          "description": "Specifies the download document capability configuration including whether it is supported and the supported MIME types for failed documents."
        }
      },
      "required": [
        "supported_countries",
        "supported_currencies",
        "retrieve_activation_supported",
        "retrieve_business_entities_supported",
        "retrieve_input_fields_supported",
        "retrieve_einvoice_status_supported",
        "document_download"
      ],
      "examples": [
        {
            "supported_countries": [
                "DE", "AT", "FR", "IT", "ES", "NL", "PL", "PT", "SE", "FI", "NO", "DK", "BE"
            ],
            "supported_currencies": [
                "USD", "EUR", "GBP", "AUD", "CAD", "JPY", "INR", "CNY", "BRL", "MXN"
            ],
            "retrieve_activation_supported": true,
            "retrieve_business_entities_supported": true,
            "retrieve_input_fields_supported": true,
            "retrieve_einvoice_status_supported": true,
            "customer_identifiers": {
                "FR": [
                    {
                        "id": "buyer_reference",
                        "display_name": "Buyer Reference",
                        "description": "Reference provided by the buyer for invoice routing or matching.",
                        "value_type": "string",
                        "is_mandatory": true,
                        "is_checkout_collectable": true,
                        "is_visible_in_admin_ui": true,
                        "validation": {
                            "min_length": 1,
                            "max_length": 100,
                            "pattern": "^[A-Za-z0-9._\\- ]+$",
                            "error_message": "Buyer Reference must be alphanumeric and may contain spaces, dots, underscores, or hyphens."
                        }
                    },
                    {
                        "id": "payer_details",
                        "display_name": "Payer Details",
                        "description": "Details of the payer when payer is different from buyer.",
                        "value_type": "object",
                        "is_mandatory": false,
                        "is_checkout_collectable": false,
                        "is_visible_in_admin_ui": true,
                        "schema": {
                            "required": ["legal_name", "postal_address"],
                            "properties": {
                                "legal_name": {
                                    "id": "legal_name",
                                    "display_name": "Payer Legal Name",
                                    "value_type": "string",
                                    "is_mandatory": true,
                                    "is_checkout_collectable": false,
                                    "is_visible_in_admin_ui": true,
                                    "validation": {
                                        "min_length": 1,
                                        "max_length": 200,
                                        "error_message": "Payer legal name is required."
                                    }
                                },
                                "postal_address": {
                                    "id": "postal_address",
                                    "display_name": "Payer Postal Address",
                                    "value_type": "object",
                                    "is_mandatory": true,
                                    "is_checkout_collectable": false,
                                    "is_visible_in_admin_ui": true,
                                    "schema": {
                                        "required": ["city", "country_code"],
                                        "properties": {
                                            "city": {
                                                "id": "city",
                                                "display_name": "City",
                                                "value_type": "string",
                                                "is_mandatory": true,
                                                "is_checkout_collectable": false,
                                                "is_visible_in_admin_ui": true,
                                                "validation": {
                                                    "min_length": 1,
                                                    "max_length": 80
                                                }
                                            },
                                            "country_code": {
                                                "id": "country_code",
                                                "display_name": "Country Code",
                                                "value_type": "string",
                                                "is_mandatory": true,
                                                "is_checkout_collectable": false,
                                                "is_visible_in_admin_ui": true,
                                                "validation": {
                                                    "pattern": "^[A-Z]{2}$",
                                                    "allowed_values": ["FR"],
                                                    "error_message": "Country code must be FR."
                                                }
                                            }
                                        }
                                    }
                                },
                                "identifiers": {
                                    "id": "identifiers",
                                    "display_name": "Payer Identifiers",
                                    "description": "Legal or tax identifiers for the payer.",
                                    "value_type": "array",
                                    "is_mandatory": false,
                                    "is_checkout_collectable": false,
                                    "is_visible_in_admin_ui": true,
                                    "schema": {
                                        "items": {
                                            "id": "payer_identifier",
                                            "display_name": "Payer Identifier",
                                            "value_type": "object",
                                            "is_mandatory": true,
                                            "is_checkout_collectable": false,
                                            "is_visible_in_admin_ui": true,
                                            "schema": {
                                                "required": ["scheme", "value"],
                                                "properties": {
                                                    "scheme": {
                                                        "id": "scheme",
                                                        "display_name": "Scheme",
                                                        "value_type": "string",
                                                        "is_mandatory": true,
                                                        "is_checkout_collectable": false,
                                                        "is_visible_in_admin_ui": true,
                                                        "validation": {
                                                            "allowed_values": ["SIREN", "SIRET", "VAT", "GLN", "OTHER"],
                                                            "max_length": 20
                                                        }
                                                    },
                                                    "value": {
                                                        "id": "value",
                                                        "display_name": "Identifier Value",
                                                        "value_type": "string",
                                                        "is_mandatory": true,
                                                        "is_checkout_collectable": false,
                                                        "is_visible_in_admin_ui": true,
                                                        "validation": {
                                                            "min_length": 1,
                                                            "max_length": 100
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    {
                        "id": "party_identifiers",
                        "display_name": "Party Identifiers",
                        "description": "Customer legal, tax, endpoint, or routing identifiers.",
                        "value_type": "array",
                        "is_mandatory": false,
                        "is_checkout_collectable": false,
                        "is_visible_in_admin_ui": true,
                        "schema": {
                            "items": {
                                "id": "party_identifier",
                                "display_name": "Party Identifier",
                                "value_type": "object",
                                "is_mandatory": true,
                                "is_checkout_collectable": false,
                                "is_visible_in_admin_ui": true,
                                "schema": {
                                    "required": ["type", "value"],
                                    "properties": {
                                        "type": {
                                            "id": "type",
                                            "display_name": "Identifier Type",
                                            "value_type": "string",
                                            "is_mandatory": true,
                                            "is_checkout_collectable": false,
                                            "is_visible_in_admin_ui": true,
                                            "validation": {
                                                "allowed_values": ["LEGAL", "VAT", "SIREN", "SIRET", "ENDPOINT", "OTHER"]
                                            }
                                        },
                                        "scheme": {
                                            "id": "scheme",
                                            "display_name": "Scheme",
                                            "value_type": "string",
                                            "is_mandatory": false,
                                            "is_checkout_collectable": false,
                                            "is_visible_in_admin_ui": true,
                                            "validation": {
                                                "max_length": 20
                                            }
                                        },
                                        "value": {
                                            "id": "value",
                                            "display_name": "Identifier Value",
                                            "value_type": "string",
                                            "is_mandatory": true,
                                            "is_checkout_collectable": false,
                                            "is_visible_in_admin_ui": true,
                                            "validation": {
                                                "min_length": 1,
                                                "max_length": 100
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                ],
                "DE": [
                    {
                        "id": "vat_number",
                        "display_name": "VAT Number",
                        "value_type": "string",
                        "is_mandatory": true,
                        "is_checkout_collectable": true,
                        "is_visible_in_admin_ui": true,
                        "validation": {
                            "pattern": "^DE[0-9]{9}$",
                            "error_message": "German VAT number must start with 'DE' followed by 9 digits."
                        }
                    }
                ],
                "EU": [
                    {
                        "id": "buyer_reference",
                        "display_name": "Buyer Reference",
                        "value_type": "string",
                        "is_mandatory": true,
                        "is_checkout_collectable": true,
                        "is_visible_in_admin_ui": true,
                        "validation": {
                            "min_length": 1,
                            "max_length": 100
                        }
                    }
                ]
            },
            "document_download": {
                "is_supported": true,
                "failed_document_mime_types": [
                    "application/vnd.oasis.ubl+xml",
                    "application/xml"
                ]
              }
          }
      ],
      "title": "Capabilities"
    },
    "CustomerIdentifiers": {
      "type": "object",
      "description": "Specifies the customer identifiers required for E-invoicing as a map keyed by ISO 3166-1 alpha-2 country code (or a 2-letter region code such as 'EU'). The value for each country/region is the ordered list of identifier fields the provider expects for customers in that jurisdiction.",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[A-Z]{2}$",
        "description": "Two-letter uppercase country code (ISO 3166-1 alpha-2) or a 2-letter region code such as 'EU'."
      },
      "additionalProperties": {
        "type": "array",
        "description": "The list of customer identifier field definitions that apply to the given country/region key.",
        "minItems": 1,
        "items": {
          "$ref": "#/definitions/CustomerIdentifierField"
        }
      },
      "title": "CustomerIdentifiers"
    },
    "CustomerIdentifierField": {
      "type": "object",
      "description": "Defines a customer identifier field at any depth. Top-level entries appear in customer_identifiers.<country>[]. Nested entries appear in a parent field's schema.properties or schema.items. Every node uses the same shape.",
      "additionalProperties": false,
      "required": [
        "id",
        "display_name",
        "value_type",
        "is_mandatory",
        "is_checkout_collectable",
        "is_visible_in_admin_ui"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Machine identifier of the field. Must start with a lowercase letter and contain only lowercase letters, digits and underscores. When nested inside schema.properties, id MUST match the property key.",
          "pattern": "^[a-z][a-z0-9_]*$",
          "examples": [
            "buyer_reference",
            "vat_number",
            "legal_name",
            "payer_identifier"
          ]
        },
        "display_name": {
          "type": "string",
          "description": "Human-readable label shown in the Chargebee UI.",
          "minLength": 1,
          "maxLength": 100,
          "examples": [
            "Buyer Reference"
          ]
        },
        "description": {
          "type": "string",
          "description": "Optional help text describing what the field is used for.",
          "maxLength": 500
        },
        "value_type": {
          "type": "string",
          "description": "Logical data type of the field. Use 'object' or 'array' for structured values, in which case a 'schema' must also be provided.",
          "enum": [
            "string",
            "number",
            "integer",
            "boolean",
            "date",
            "datetime",
            "object",
            "array"
          ]
        },
        "is_mandatory": {
          "type": "boolean",
          "description": "Whether the field must be supplied on the customer record."
        },
        "is_checkout_collectable": {
          "type": "boolean",
          "description": "Whether the field should be collected from the buyer during hosted checkout."
        },
        "is_visible_in_admin_ui": {
          "type": "boolean",
          "description": "Whether the field should be shown on the customer details page in the Chargebee admin UI."
        },
        "validation": {
          "$ref": "#/definitions/CustomerIdentifierValidation",
          "description": "Optional value-level constraints applied to scalar fields (length, pattern, allowed values, etc.)."
        },
        "schema": {
          "$ref": "#/definitions/CustomerIdentifierFieldSchema",
          "description": "Required when value_type is 'object' or 'array'. Describes the structure of the value."
        }
      },
      "oneOf": [
        {
          "description": "Object fields MUST declare schema with properties.",
          "properties": {
            "value_type": {
              "const": "object"
            }
          },
          "required": [
            "schema"
          ],
          "allOf": [
            {
              "properties": {
                "schema": {
                  "required": [
                    "properties"
                  ]
                }
              }
            }
          ]
        },
        {
          "description": "Array fields MUST declare schema with items.",
          "properties": {
            "value_type": {
              "const": "array"
            }
          },
          "required": [
            "schema"
          ],
          "allOf": [
            {
              "properties": {
                "schema": {
                  "required": [
                    "items"
                  ]
                }
              }
            }
          ]
        },
        {
          "description": "Scalar values MUST NOT declare a 'schema'.",
          "properties": {
            "value_type": {
              "enum": [
                "string",
                "number",
                "integer",
                "boolean",
                "date",
                "datetime"
              ]
            }
          },
          "not": {
            "required": [
              "schema"
            ]
          }
        }
      ],
      "title": "CustomerIdentifierField"
    },
    "CustomerIdentifierValidation": {
      "type": "object",
      "description": "Value-level constraints applied to a scalar customer identifier field.",
      "additionalProperties": false,
      "properties": {
        "min_length": {
          "type": "integer",
          "description": "Minimum string length. Applies to value_type 'string'.",
          "minimum": 0
        },
        "max_length": {
          "type": "integer",
          "description": "Maximum string length. Applies to value_type 'string'.",
          "minimum": 1
        },
        "minimum": {
          "type": "number",
          "description": "Inclusive lower bound. Applies to value_type 'number' or 'integer'."
        },
        "maximum": {
          "type": "number",
          "description": "Inclusive upper bound. Applies to value_type 'number' or 'integer'."
        },
        "pattern": {
          "type": "string",
          "description": "Regular expression the string value must match."
        },
        "format": {
          "type": "string",
          "description": "Semantic format hint for the value.",
          "enum": [
            "email",
            "uri",
            "date",
            "datetime"
          ]
        },
        "allowed_values": {
          "type": "array",
          "description": "Closed set of allowed values for the field.",
          "items": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          },
          "uniqueItems": true
        },
        "error_message": {
          "type": "string",
          "description": "Optional override error message shown when validation fails."
        }
      },
      "title": "CustomerIdentifierValidation"
    },
    "CustomerIdentifierFieldSchema": {
      "type": "object",
      "description": "Structural schema for a field whose value_type is 'object' or 'array'. Nested nodes are full CustomerIdentifierField instances.",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "description": "Ids of required child properties when the parent value_type is 'object'. Each entry MUST match a key in properties.",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "uniqueItems": true
        },
        "properties": {
          "type": "object",
          "description": "Property name to CustomerIdentifierField map. Required when parent value_type is 'object'.",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/definitions/CustomerIdentifierField"
          }
        },
        "items": {
